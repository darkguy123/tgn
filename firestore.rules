
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Safely check for admin privileges.
      // 1. Check hardcoded super-admin email
      // 2. Check user document role if it exists
      return isSignedIn() && (
        (request.auth.token.email == 'valentinoboss18@gmail.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['country-manager', 'admin'])
      );
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      // 👀 Anyone signed in can view all profiles (important for directory and feed)
      allow read: if isSignedIn();
      
      // ✍️ User can create their own doc. Admin can too.
      allow create: if isOwner(userId) || isAdmin();
      
      // ✏️ User can update their own doc (but logic should prevent changing role via UI). Admin can do anything.
      allow update: if isOwner(userId) || isAdmin();

      // Subcollections
      match /media/{mediaId} {
        allow read: if true;
        allow create, delete: if isOwner(userId) || isAdmin();
        allow update: if false;
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /transactions/{transactionId} {
        allow create: if isOwner(userId);
        allow read: if isOwner(userId) || isAdmin();
        allow update: if isAdmin(); 
        allow delete: if false;
      }
      match /enrolled_programs/{programId} {
          allow read, create: if isOwner(userId) || isAdmin();
          allow update, delete: if isAdmin();
      }
      match /menteeVerifications/{verificationId} {
          allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Wallets are private to the owner and admin
    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- COMMUNITY POSTS (Social Media) ---
    match /posts/{postId} {
      // 👀 Allow any authenticated user to view the feed and individual posts
      allow read: if isSignedIn();

      // ✍️ Create post (author must be the creator)
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;

      // ✏️ Update: Allow any signed-in user to update (for liking/saving posts)
      // Note: Application logic should ensure they only update likes/savedBy arrays
      allow update: if isSignedIn();
      
      // 🗑️ Delete only by the creator or an admin
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      }
    }

    // --- MARKETPLACE & CONTENT ---
    match /products/{productId} {
      // Products are publicly viewable
      allow read: if true;
      
      // Create product (must be the seller)
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      
      // Update/Delete: only by the seller or admin
      allow update, delete: if (isSignedIn() && resource.data.sellerMemberId == request.auth.uid) || isAdmin();
    }

    match /programs/{programId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sectors/{sectorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- ADS & CAUSES ---
    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /causes/{causeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // For contributing funds
    }
    
    // --- MESSAGING ---
    match /chats/{chatId} {
      // Check if user is one of the participants via the ID pattern or members field
      allow read: if isSignedIn() && (request.auth.uid in chatId.split('_') || request.auth.uid in resource.data.members);
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in chatId.split('_');
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    match /friend_requests/{friendRequestId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    match /connections/{connectionId} {
      // Connections are readable by the network members involved
      allow read: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid in connectionId.split('_');
    }
    
    // --- ADMIN & CERTIFICATION ---
    match /mentor_certifications/{memberId} {
      allow read: if isOwner(memberId) || isAdmin();
      allow write: if isAdmin();
    }

    match /mentor_kyc/{memberId} {
      allow read: if isOwner(memberId) || isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin();
    }
    
    // --- AFFILIATE SYSTEM ---
    match /commissions/{commissionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn(); 
      allow update, delete: if false;
    }
    
    match /affiliate_referrals/{referralId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.referrerMemberId == request.auth.uid || resource.data.referredMemberId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}

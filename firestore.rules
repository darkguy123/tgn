
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'valentinoboss18@gmail.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'mentee') in ['country-manager', 'admin'])
      );
    }

    // --- USER-OWNED DATA ---
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();

      match /media/{mediaId} {
        allow read: if true;
        allow create, delete: if isOwner(userId) || isAdmin();
        allow update: if false;
      }

      match /cards/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /transactions/{transactionId} {
        allow create: if isOwner(userId);
        allow read: if isOwner(userId) || isAdmin();
        allow update: if isAdmin(); 
        allow delete: if false;
      }

      match /enrolled_programs/{programId} {
        allow read, create: if isOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }

      match /menteeVerifications/{verificationId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- POSTS (FORCE READ) ---
    match /posts {
      allow list: if true;
    }
    match /posts/{postId} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      
      // Allow update if owner OR if only social fields (likes, commentsCount, savedBy) are changing
      allow update: if isSignedIn() && (
        (resource.data.authorId == request.auth.uid || isAdmin()) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount', 'savedBy']))
      );
      
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      }
    }

    // --- MARKETPLACE & CONTENT (FORCE READ) ---
    match /products {
      allow list: if true;
    }
    match /products/{productId} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      allow update, delete: if (isSignedIn() && resource.data.sellerMemberId == request.auth.uid) || isAdmin();
    }

    match /programs {
      allow list: if true;
    }
    match /programs/{programId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /events {
      allow list: if true;
    }
    match /events/{eventId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /sectors {
      allow list: if true;
    }
    match /sectors/{sectorId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    // --- COMMUNITY & ADS ---
    match /ads {
      allow list: if true;
    }
    match /ads/{adId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /causes {
      allow list: if true;
    }
    match /causes/{causeId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // --- CHAT & CONNECTIONS ---
    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in chatId.split('_');
      allow list: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in chatId.split('_');
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // --- FRIEND REQUESTS ---
    match /friend_requests {
      allow list: if isSignedIn();
    }
    match /friend_requests/{friendRequestId} {
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    match /connections {
      allow list: if isSignedIn();
    }
    match /connections/{connectionId} {
      allow get: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid in connectionId.split('_');
    }

    // --- ADMIN & VERIFICATION ---
    match /mentor_certifications/{memberId} {
      allow get, list: if isOwner(memberId) || isAdmin();
      allow write: if isAdmin();
    }

    match /mentor_kyc/{memberId} {
      allow get, list: if isOwner(memberId) || isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin();
    }

    // --- AFFILIATE SYSTEM ---
    match /commissions {
      allow list: if isSignedIn();
    }
    match /commissions/{commissionId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- GLOBAL FALLBACK ---
    match /{document=**} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}

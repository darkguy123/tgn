rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Hardcoded admin email + role-based admin
      return (request.auth.token.email == 'valentinoboss18@gmail.com') || 
             (
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'country-manager'
             );
    }
    
    // --- GLOBAL ADMIN RULE ---
    // Admins have universal read/write access to all data.
    match /{path=**} {
        allow read, write: if isAdmin();
    }

    // --- USER-SPECIFIC RULES (for non-admins) ---

    // USERS collection and subcollections
    match /users/{userId} {
      // Users can read public profiles
      allow get, list: if isSignedIn();
      // Users can create and update their own profile, but only admins can change roles.
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && !(request.resource.data.role != resource.data.role);

      // Media subcollection rules
      match /media/{mediaId} {
        allow read: if true; // Publicly readable
        allow create, delete: if isOwner(userId);
        allow update: if false; // No updates allowed
      }
    }

    // PROGRAMS collection
    match /programs/{programId} {
      allow read: if isSignedIn();
      // Only admins can write to programs (covered by global rule)
      allow write: if false; 
    }

    // MENTOR CERTIFICATIONS
    match /mentor_certifications/{memberId} {
      allow read: if isOwner(memberId);
       // Only admins can write (covered by global rule)
      allow write: if false;
    }
    
    // Other collections...
    match /events/{eventId} {
      allow read: if true;
      allow write: if false; // Admins only
    }
    
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(resource.data.sellerMemberId);
    }
  }
}

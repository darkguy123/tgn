rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================== */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'valentinoboss18@gmail.com' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'mentee')
            in ['admin', 'country-manager']
        )
      );
    }

    /* =========================
       APP SETTINGS
    ========================== */
    match /app_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* =========================
       USERS
    ========================== */
    match /users/{userId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();

      match /media/{id} {
        allow list, get, write: if isOwner(userId) || isAdmin();
      }
      match /cards/{id} {
        allow list, get, write: if isOwner(userId) || isAdmin();
      }
      match /transactions/{id} {
        allow list, get, write: if isOwner(userId) || isAdmin();
      }
      match /enrolled_programs/{id} {
        allow list, get, write: if isOwner(userId) || isAdmin();
      }
    }

    match /wallets/{userId} {
      allow get, write: if isOwner(userId) || isAdmin();
    }

    /* =========================
       POSTS (FINAL PERMANENT FIX)
    ========================== */
    match /posts/{postId} {
      // Defining 'list' inside the wildcard is the only guaranteed way to authorize /posts queries
      allow list: if isSignedIn();
      allow get: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;

      // Allow social interactions (likes, saves) for everyone
      allow update: if isSignedIn();

      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.authorId == request.auth.uid);

      match /comments/{commentId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin()
          || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }

    /* =========================
       MARKETPLACE & CONTENT
    ========================== */
    match /products/{productId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn()
        && request.resource.data.sellerMemberId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid);
    }

    match /programs/{programId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow list: if true;
      allow get: if true;
      allow write: if isAdmin();
    }

    match /sectors/{sectorId} {
      allow list: if true;
      allow get: if true;
      allow write: if isAdmin();
    }

    match /causes/{causeId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();

      // Admins can fully manage causes. Members can only increment funding counters.
      allow update: if isAdmin() || (
        isSignedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['currentAmount', 'backersCount'])
        && request.resource.data.currentAmount >= resource.data.currentAmount
        && request.resource.data.backersCount >= resource.data.backersCount
      );
    }

    /* =========================
       FRIEND REQUESTS
    ========================== */
    match /friend_requests/{requestId} {
      allow list: if isSignedIn();
      allow get, update, delete: if isSignedIn()
        && (
          resource.data.senderId == request.auth.uid ||
          resource.data.recipientId == request.auth.uid
        );

      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid;
    }

    /* =========================
       CHATS
    ========================== */
    match /chats/{chatId} {
      allow list: if isSignedIn();
      allow get, create, update: if isSignedIn()
        && (request.auth.uid in chatId.split('_') || request.auth.uid in resource.data.members);

      match /messages/{messageId} {
        allow list: if isSignedIn();
        allow read, create: if isSignedIn();
      }
    }

    /* =========================
       CONNECTIONS
    ========================== */
    match /connections/{connectionId} {
      allow list: if isSignedIn();
      allow get, create, delete: if isSignedIn()
        && request.auth.uid in connectionId.split('_');
    }

    /* =========================
       AFFILIATE & ADMIN
    ========================== */
    match /mentor_certifications/{memberId} {
      allow get, list, write: if isOwner(memberId) || isAdmin();
    }

    match /mentor_kyc/{memberId} {
      allow list: if isAdmin();
      allow get: if isOwner(memberId) || isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin();
    }

    match /commissions/{commissionId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn();
    }

    match /affiliate_referrals/{referralId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || (isSignedIn() && (resource.data.referrerMemberId == request.auth.uid || resource.data.referredMemberId == request.auth.uid));
      allow create: if isSignedIn();
    }

    match /ads/{adId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    /* =========================
       COLLECTION GROUPS
    ========================== */
    match /{path=**}/transactions/{transactionId} {
      allow list: if isAdmin();
    }

    /* =========================
       GLOBAL FALLBACK
    ========================== */
    match /{doc=**} {
      allow get: if isSignedIn();
      allow list: if false; // collections must be explicit
      allow write: if false;
    }
  }
}
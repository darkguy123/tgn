/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for personal data and a shared-access model for collaborative entities. The primary goal is to ensure that users can only access and manage their own information while allowing controlled read access to shared resources they are a part of.
 *
 * Data Structure: The data is organized into two main categories:
 * 1. User-Private Data: All data exclusively owned by a user (like their profile and learning history) is nested under the `/users/{userId}` path. This creates a secure, hierarchical data tree for each user.
 * 2. Shared/Public Data: Top-level collections like `/programs`, `/communities`, and `/marketplaceListings` store data that can be accessed by multiple users, with access controlled by denormalized fields on each document.
 *
 * Key Security Decisions:
 * - User Isolation: Users are strictly forbidden from reading or listing other users' profiles or private subcollections. The `/users` collection is not listable.
 * - Shared Access via Membership: Access to collaborative documents (like `/programs`, `/communities`, `/events`) is granted if a user's UID is present in the `memberIds` array on the document. Client-side writes to these collections are disabled by default, assuming they are managed by backend processes or admins.
 * - Owner-Only Writes for Public Content: The `/marketplaceListings` collection is publicly readable, but write operations (create, update, delete) are restricted to the user whose UID matches the `sellerMemberId` field on the document.
 * - Secure Default for Ambiguous Ownership: Collections like `/mentorCertifications` and `/affiliateReferrals` lack a direct, verifiable ownership field (like a `userId`). To prevent potential data leaks, all client access to these collections is disabled until a secure ownership model is implemented.
 * - Denormalization for Authorization: The rules rely on denormalized authorization fields (e.g., `sellerMemberId`, `memberIds`) directly on the documents being secured. This avoids slow and costly `get()` calls in rules, leading to better performance and simpler logic.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the foundation of the ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Ensures a document exists before allowing a state-changing operation (update, delete).
     * This prevents unauthorized writes on non-existent paths.
     */
    function docExists() {
      return resource != null;
    }

    /**
     * Combines ownership check with an existence check for update/delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && docExists();
    }
    
    /**
     * Checks if the authenticated user's UID is in a list of member IDs.
     * Used for shared documents like programs, communities, and events.
     */
    function isMember(docData) {
      return isSignedIn() && request.auth.uid in docData.memberIds;
    }

    /**
     * Validates that the user's root document is being created correctly.
     * Enforces that the internal 'id' field matches the user's Auth UID.
     */
    function createUserValidation(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * Validates updates to a user's root document.
     * Enforces ownership and makes the internal 'id' field immutable.
     */
    function updateUserValidation(userId) {
      return isOwner(userId) && docExists() && request.resource.data.id == resource.data.id;
    }

    // --------------------------------------------------------------------
    // User Data (/users)
    // --------------------------------------------------------------------

    /**
     * @description A user can create, read, and update their own profile document. They cannot delete their own profile or view others' profiles.
     * @path /users/{userId}
     * @allow (create) A newly authenticated user (auth.uid='user123') creating their own document at `/users/user123` with `{id: 'user123', ...}`.
     * @deny (get) User 'user456' trying to read the document at `/users/user123`.
     * @principle Restricts access to a user's own data tree, enforcing strict data privacy and ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if createUserValidation(userId);
      allow update: if updateUserValidation(userId);
      allow delete: if false;

      /**
       * @description A user can fully manage their own learning history entries.
       * @path /users/{userId}/learningHistories/{learningHistoryId}
       * @allow (list) User 'user123' listing all documents in their `/users/user123/learningHistories` collection.
       * @deny (get) User 'user456' trying to read a document at `/users/user123/learningHistories/history_abc`.
       * @principle Enforces that access to subcollection data is governed by ownership of the parent document.
       */
      match /learningHistories/{learningHistoryId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    // --------------------------------------------------------------------
    // Ambiguous Ownership Collections (Secured by Default)
    // --------------------------------------------------------------------

    /**
     * @description Stores mentor certifications. All client access is disabled because the document lacks a direct `ownerId` or `userId` field linked to Firebase Auth, making secure rules impossible.
     * @path /mentorCertifications/{mentorCertificationId}
     * @allow None. All client requests are denied.
     * @deny (get) Any user attempting to read a certification document.
     * @principle Defaults to a secure posture by denying access to collections where ownership cannot be definitively verified.
     */
    match /mentorCertifications/{mentorCertificationId} {
      // CRITICAL: Cannot implement secure rules. The 'MentorCertification' entity is missing an 'ownerId' or 'userId' field linked to Firebase Auth.
      allow get: if false; // TODO: Add owner validation once the schema is updated.
      allow list: if false; // TODO: Add owner validation once the schema is updated.
      allow create: if false; // TODO: Add owner validation once the schema is updated.
      allow update: if false; // TODO: Add owner validation once the schema is updated.
      allow delete: if false; // TODO: Add owner validation once the schema is updated.
    }
    
    /**
     * @description Stores affiliate referral data. All client access is disabled due to the lack of a verifiable ownership field linked to Firebase Auth.
     * @path /affiliateReferrals/{affiliateReferralId}
     * @allow None. All client requests are denied.
     * @deny (create) Any user attempting to create a new referral document.
     * @principle Defaults to a secure posture by denying access to collections where ownership cannot be definitively verified.
     */
    match /affiliateReferrals/{affiliateReferralId} {
      // CRITICAL: Cannot implement secure rules. The 'AffiliateReferral' entity is missing ownerId fields linked to Firebase Auth UIDs.
      allow get: if false; // TODO: Add owner validation once the schema is updated.
      allow list: if false; // TODO: Add owner validation once the schema is updated.
      allow create: if false; // TODO: Add owner validation once the schema is updated.
      allow update: if false; // TODO: Add owner validation once the schema is updated.
      allow delete: if false; // TODO: Add owner validation once the schema is updated.
    }

    // --------------------------------------------------------------------
    // Shared Data (Programs, Communities, Events)
    // --------------------------------------------------------------------
    
    /**
     * @description Signed-in users can discover programs. Only members of a program can read its specific details. All client-side writes are disabled.
     * @path /programs/{programId}
     * @allow (get) User 'user123' reading a program where `resource.data.memberIds` contains 'user123'.
     * @deny (get) User 'user456' reading a program where they are not in the `memberIds` list.
     * @deny (update) Any user trying to modify a program's details.
     * @principle Implements a closed collaborator model where read access is granted based on membership.
     */
    match /programs/{programId} {
      allow get: if isMember(resource.data);
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    
    /**
     * @description Signed-in users can discover communities. Only members of a community can read its specific details. All client-side writes are disabled.
     * @path /communities/{communityId}
     * @allow (get) User 'user123' reading a community where `resource.data.memberIds` contains 'user123'.
     * @deny (get) User 'user456' reading a community where they are not in the `memberIds` list.
     * @principle Implements a closed collaborator model where read access is granted based on membership.
     */
    match /communities/{communityId} {
      allow get: if isMember(resource.data);
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Signed-in users can discover events. Only members of an event can read its specific details. All client-side writes are disabled.
     * @path /events/{eventId}
     * @allow (get) User 'user123' reading an event where `resource.data.memberIds` contains 'user123'.
     * @deny (get) User 'user456' reading an event where they are not in the `memberIds` list.
     * @principle Implements a closed collaborator model where read access is granted based on membership.
     */
    match /events/{eventId} {
      allow get: if isMember(resource.data);
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // --------------------------------------------------------------------
    // Public/Reference Data
    // --------------------------------------------------------------------
    
    /**
     * @description Course information is readable by any signed-in user but cannot be modified by clients.
     * @path /courses/{courseId}
     * @allow (list) Any authenticated user listing all available courses.
     * @deny (create) A regular user attempting to add a new course document.
     * @principle Provides secure, read-only access to public reference data.
     */
    match /courses/{courseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Marketplace listings are publicly readable. Only the seller can create, update, or delete their own listings.
     * @path /marketplaceListings/{marketplaceListingId}
     * @allow (create) User 'seller123' creating a new listing with `{ sellerMemberId: 'seller123', ... }`.
     * @allow (list) Any user, signed-in or not, viewing all marketplace listings.
     * @deny (update) User 'user456' attempting to change the price on a listing owned by 'seller123'.
     * @principle Enforces a "Public Read with Owner-Only Writes" model, ideal for public content creation platforms.
     */
    match /marketplaceListings/{marketplaceListingId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.sellerMemberId);
      allow delete: if isExistingOwner(resource.data.sellerMemberId);
    }
    
    /**
     * @description Package benefit information is readable by any signed-in user but cannot be modified by clients.
     * @path /packageBenefits/{packageBenefitId}
     * @allow (get) Any authenticated user reading the details of a package benefit.
     * @deny (delete) A regular user attempting to delete a package benefit document.
     * @principle Provides secure, read-only access to public reference data.
     */
    match /packageBenefits/{packageBenefitId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    
    /**
     * @description Sector information is readable by any signed-in user but cannot be modified by clients.
     * @path /sectors/{sectorId}
     * @allow (list) Any authenticated user listing all available business sectors.
     * @deny (update) A regular user attempting to change a sector's description.
     * @principle Provides secure, read-only access to public reference data.
     */
    match /sectors/{sectorId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

  }
}
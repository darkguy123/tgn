rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Safely check for admin privileges.
      return isSignedIn() && (
        (request.auth.token.email == 'valentinoboss18@gmail.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['country-manager', 'admin'])
      );
    }

    // --- USERS ---
    match /users {
      // 🔑 COLLECTION-LEVEL RULE
      allow list: if isSignedIn();
    }
    
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && (request.resource.data.get('role', 'mentee') == resource.data.get('role', 'mentee'))) || isAdmin();

      match /media/{mediaId} {
        allow read: if true;
        allow create, delete: if isOwner(userId) || isAdmin();
        allow update: if false;
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /transactions/{transactionId} {
        allow create: if isOwner(userId);
        allow read: if isOwner(userId) || isAdmin();
        allow update: if isAdmin(); 
        allow delete: if false;
      }
      match /enrolled_programs/{programId} {
          allow read, create: if isOwner(userId) || isAdmin();
          allow update, delete: if isAdmin();
      }
      match /menteeVerifications/{verificationId} {
          allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- POSTS ---
    match /posts {
      // 🔑 COLLECTION-LEVEL RULE
      allow list: if isSignedIn();
    }

    match /posts/{postId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      }
    }

    // --- CHAT & MESSAGES ---
    match /chats {
      // 🔑 COLLECTION-LEVEL RULE
      allow list: if isSignedIn();
    }

    match /chats/{chatId} {
      // Users can get a chat if they are a member
      allow get: if isSignedIn() && (request.auth.uid in resource.data.members || request.auth.uid in chatId.split('_'));
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        // Users can read messages if they are a member of the parent chat
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // --- FRIEND REQUESTS ---
    match /friend_requests {
      // 🔑 COLLECTION-LEVEL RULE
      allow list: if isSignedIn();
    }

    match /friend_requests/{friendRequestId} {
      // Only sender or recipient can read individual requests
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      
      // Only sender can create
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      
      // Recipient can update (accept/decline) or sender can update (cancel)
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid || resource.data.senderId == request.auth.uid);
      
      // Both parties can delete
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    // --- CONNECTIONS ---
    match /connections {
      // 🔑 COLLECTION-LEVEL RULE
      allow list: if isSignedIn();
    }
    match /connections/{connectionId} {
      allow get: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid in connectionId.split('_');
    }

    // --- MARKETPLACE & CONTENT ---
    match /products {
      allow list: if true;
    }
    match /products/{productId} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      allow update, delete: if (isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid) || isAdmin();
    }

    match /programs {
      allow list: if isSignedIn();
    }
    match /programs/{programId} {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }

    match /events {
      allow list: if true;
    }
    match /events/{eventId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /sectors {
      allow list: if true;
    }
    match /sectors/{sectorId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    // --- ADS & CAUSES ---
    match /ads {
      allow list: if true;
    }
    match /ads/{adId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /causes {
      allow list: if true;
    }
    match /causes/{causeId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
    }
    
    // --- ADMIN & VERIFICATION ---
    match /mentor_certifications/{memberId} {
      allow read: if isOwner(memberId) || isAdmin();
      allow write: if isAdmin();
    }

    match /mentor_kyc/{memberId} {
      allow read: if isOwner(memberId) || isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin();
    }
    
    // --- AFFILIATE SYSTEM ---
    match /commissions {
      allow list: if isSignedIn();
    }
    match /commissions/{commissionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn(); 
      allow update, delete: if false;
    }
    
    match /affiliate_referrals {
      allow list: if isSignedIn();
    }
    match /affiliate_referrals/{referralId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.referrerMemberId == request.auth.uid || resource.data.referredMemberId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
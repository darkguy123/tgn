
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Safely check for admin privileges.
      return isSignedIn() && (
        (request.auth.token.email == 'valentinoboss18@gmail.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['country-manager', 'admin'])
      );
    }

    // --- USER-OWNED DATA ---
    match /users/{userId} {
      // Allow any signed-in user to view profiles or list users (for directory/search)
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId);
      // User can update their own doc (but not their role). Admin can do anything.
      allow update: if (isOwner(userId) && !(request.resource.data.role != resource.data.role)) || isAdmin();

      // Subcollections
      match /media/{mediaId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId);
      }
      match /transactions/{transactionId} {
        allow create: if isOwner(userId);
        allow read: if isOwner(userId) || isAdmin();
        allow update: if isAdmin(); 
        allow delete: if false;
      }
      match /enrolled_programs/{programId} {
          allow read, create: if isOwner(userId);
          allow update, delete: if false;
      }
      match /menteeVerifications/{verificationId} {
          allow read, write: if isOwner(userId);
      }
    }
    
    // Wallets are private to the owner and admin
    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- GLOBAL/PUBLIC DATA ---
    match /programs/{programId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    match /sectors/{sectorId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /events/{eventId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --- COMMUNITY & FEED ---
    match /posts/{postId} {
      // Allow all signed-in users to view the feed and individual posts
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      // Allow updating for likes/saves. In a production app, you'd restrict this to only those fields.
      allow update: if isSignedIn();
      // Only the author or an admin can delete
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      allow update, delete: if (isSignedIn() && resource.data.sellerMemberId == request.auth.uid) || isAdmin();
    }

    match /ads/{adId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /causes/{causeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // For contributing
    }
    
    // --- CHAT & CONNECTIONS ---
    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in chatId.split('_');
      allow list: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in chatId.split('_');
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid && request.auth.uid in chatId.split('_');
        allow update, delete: if false;
      }
    }
    
    match /friend_requests/{friendRequestId} {
      allow get, list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    match /connections/{connectionId} {
      allow get, list: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid in connectionId.split('_');
    }
    
    // --- ADMIN & VERIFICATION ---
    match /mentor_certifications/{memberId} {
      allow get, list: if isOwner(memberId) || isAdmin();
      allow write: if isAdmin();
    }

    match /mentor_kyc/{memberId} {
      allow get, list: if isOwner(memberId) || isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin();
    }
    
    // --- AFFILIATE SYSTEM ---
    match /commissions/{commissionId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn(); 
      allow update, delete: if false;
    }
    
    match /affiliate_referrals/{referralId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource.data.referrerMemberId == request.auth.uid || resource.data.referredMemberId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}

/**
 * Core Philosophy:
 * This ruleset enforces a user-centric security model where users have full control
 * over their own data, while interacting with shared or public data in a controlled manner.
 * The primary principle is "Authorization Independence," where authorization data is
 * denormalized onto documents to create simple, performant, and secure rules without
 * needing cross-document reads (`get()`).
 *
 * Data Structure:
 * The data is organized into a mix of a primary user-owned tree and several top-level
 * collections.
 * - /users/{userId}: The root for all data strictly private to a single user.
 * - Top-Level Collections (/products, /wallets, /events, etc.): These collections
 *   contain shared or global data. Access is governed by denormalized ownership fields
 *   (e.g., `sellerMemberId`, `memberId`) within each document.
 *
 * Key Security Decisions:
 * - Controlled User Visibility: Users can only update their own data. For features like
 *   matchmaking and member directories to work, profiles are readable by other signed-in members.
 * - Denormalized Authorization: Collections like `/products` and `/wallets` rely on
 *   internal fields (`sellerMemberId`, `memberId`) to grant access. This is faster and
 *   more secure than using `get()` calls to check permissions on related documents.
 * - Public vs. Private Data: Structural segregation is used. Publicly readable
 *   information like events and sectors is stored in top-level collections with open
 *   read access. Private user data is nested under `/users`.
 * - Default to Secure: Writes to public collections (`/events`, `/sectors`) and
 *   sensitive collections (`/wallets`) are disabled by default for clients. These
 *   operations are expected to be handled by a trusted backend or an admin role,
 *   which is now implemented.
 * - No Client-Side Financial Transactions: All write operations on `/wallets` are
 *   explicitly disabled to prevent tampering. All wallet modifications must be
 *   performed by a secure backend server.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Verifies that the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifies that the requesting user's UID matches the provided userId.
     * This is the core function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Verifies ownership for an existing document. Used for safe updates and deletes.
     * Checks that the document exists (`resource != null`) and that the requester
     * is the owner based on the document's owner field.
     */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }
    
    /**
     * Verifies if the user is a super admin. This is hardcoded for a specific user.
     */
    function isSuperAdmin() {
      return request.auth.uid == 'Y9ckdC5d2RPQ533s5CfaiiXlKYi1';
    }

    /**
     * Verifies if the user has an admin role (e.g., 'country-manager') or is a super admin.
     * This requires a read to the user's own profile document.
     */
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc.data != null && (userDoc.data.role == 'country-manager' || isSuperAdmin());
    }


    // ------------------------------------------------------------------------
    // User Data (/users)
    // ------------------------------------------------------------------------

    /**
     * @description Controls access to a TGN Member's profile document.
     * @path /users/{userId}
     * @allow (get, list) - Any authenticated user can read another user's profile to enable directory and matchmaking features.
     * @allow (create) - A new user creating their own profile.
     * @allow (update) - A user can update their own non-sensitive data. An admin can update any user's data.
     * @allow (delete) - Only an admin can delete user profiles.
     * @principle Restricts write access to a user's own data tree, but allows reads for social features. Admins have override privileges.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isAdmin() ||
                    // A user can update their own profile, but not change protected fields.
                    (isOwner(userId) &&
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.isVerifiedMentor == resource.data.isVerifiedMentor &&
                     request.resource.data.id == resource.data.id &&
                     request.resource.data.tgnMemberId == resource.data.tgnMemberId
                    ) ||
                    // Allow anyone to update ONLY the connections array of another user.
                    // This is required for the two-way connection logic to work from the client.
                    (isSignedIn() && !isOwner(userId) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connections']));
      allow delete: if isAdmin();

      /**
       * @description Controls access to a user's private matchmaking recommendations.
       * @path /users/{userId}/matchmaking_recommendations/{recommendationId}
       * @allow (list) - An authenticated user listing their own recommendations.
       * @deny (get) - An authenticated user trying to read recommendations of another user.
       * @principle Enforces path-based ownership for subcollections. Writes are disallowed as recommendations are system-generated.
       */
      match /matchmaking_recommendations/{recommendationId} {
        allow get, list: if isOwner(userId);
        allow create: if false; // Recommendations are created by a backend service
        allow update: if false; // Recommendations are immutable
        allow delete: if false; // Recommendations are not deleted by users
      }
      
      /**
       * @description Controls access to a user's wallet transactions.
       * @path /users/{userId}/transactions/{transactionId}
       * @allow (get, list) - A user can read their own transaction history.
       * @allow (create) - A user can create their own transaction log (for sending money, withdrawals, etc.).
       * @deny (update, delete) - Transactions are immutable by the user.
       */
      match /transactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
      
      /**
       * @description Controls access to a user's enrolled programs.
       * @path /users/{userId}/enrolled_programs/{enrollmentId}
       * @allow (read, create, update, delete) - A user can manage their own program enrollments.
       */
      match /enrolled_programs/{enrollmentId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }


    // ------------------------------------------------------------------------
    // Public Read-Only Collections
    // ------------------------------------------------------------------------

    /**
     * @description Controls access to mentorship sectors. Data is public for all to read.
     * @path /sectors/{sectorId}
     * @allow (get, list) - Any client, authenticated or not, can read sector data.
     * @deny (create) - A signed-in user trying to create a new sector.
     * @principle Provides public read access for reference data. Writes are restricted to prevent unauthorized modifications.
     */
    match /sectors/{sectorId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    /**
     * @description Controls access to learning programs. Data is public for all to read.
     * @path /programs/{programId}
     * @allow (get, list) - Any client can read program information.
     * @allow (create, delete) - Only admins can manage programs.
     * @allow (update) - Admins can update. Users can update only the 'enrolled' count by exactly 1.
     */
    match /programs/{programId} {
      allow get, list: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || 
                      (isSignedIn() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolled']) &&
                       request.resource.data.enrolled == resource.data.enrolled + 1);
    }

    /**
     * @description Controls access to events. Event data is public for all to read.
     * @path /events/{eventId}
     * @allow (get, list) - Any client, authenticated or not, can read event information.
     * @deny (update) - A signed-in user trying to modify an event.
     * @principle Provides public read access for global data. Writes are restricted to trusted roles.
     */
    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }


    // ------------------------------------------------------------------------
    // Collections with Denormalized Ownership
    // ------------------------------------------------------------------------

    /**
     * @description Controls access to mentor KYC submissions.
     * @path /mentor_kyc/{userId}
     * @allow (read) - Only the user who submitted and admins can read it.
     * @allow (create) - A user can create their own KYC submission.
     * @allow (update) - Only admins can update the status (approve/reject).
     */
    match /mentor_kyc/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.memberId == userId;
      allow update: if isAdmin();
      allow delete: if false; // KYC records should not be deleted
    }

    /**
     * @description Controls access to affiliate referrals.
     * @path /affiliate_referrals/{referralId}
     * @allow (read) - Admins can read all referral documents.
     * @allow (get) - The user who referred or was referred can read the document.
     * @allow (list) - A user can only list referrals they have made.
     * @principle Secures data based on participation. Only the referrer can create the record. Updates/deletes are disallowed.
     */
    match /affiliate_referrals/{referralId} {
      allow read: if isAdmin();
      allow get: if isSignedIn() && (isOwner(resource.data.referrerMemberId) || isOwner(resource.data.referredMemberId));
      allow list: if (isSignedIn() && request.query.where[0][0] == "referrerMemberId" && request.query.where[0][2] == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.referrerMemberId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to mentor certifications. A mentor can view their own certification status.
     * @path /mentor_certifications/{userId}
     * @allow (read) - Admins can read all certification documents.
     * @allow (get) - A user reading their own certification document.
     * @principle Grants read-only access to the document owner. Writes are restricted to prevent self-certification.
     */
    match /mentor_certifications/{userId} {
      allow read: if isAdmin();
      allow get: if isOwner(userId);
      allow create, update, delete: if isAdmin();
    }


    /**
     * @description Controls access to user wallets. Extremely restricted.
     * @path /wallets/{userId}
     * @allow (read) - Admins and the owner can read a wallet.
     * @allow (create) - A signed-in user can create a wallet for themselves.
     * @allow (update) - Allows for secure P2P transfers and simulated deposits between clients.
     * @principle Secures sensitive financial data by only allowing balance changes under specific conditions.
     */
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.memberId == userId;
      allow update: if isAdmin() ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']) && (
                        // Allow user to DECREASE their own balance (sending funds)
                        (isOwner(userId) && request.resource.data.balance < resource.data.balance) ||
                        // Allow user to INCREASE their own balance (simulated deposit)
                        (isOwner(userId) && request.resource.data.balance > resource.data.balance) ||
                        // Allow other users to INCREASE this user's balance (receiving funds)
                        (!isOwner(userId) && request.resource.data.balance > resource.data.balance)
                    ));
      allow delete: if false; // Wallets should never be deleted
    }

    /**
     * @description Controls access to products in the marketplace. Products are publicly viewable.
     * @path /products/{productId}
     * @allow (create) - A signed-in user creating a product listing and setting themselves as the seller.
     * @deny (update) - A user trying to update a product owned by another user.
     * @principle Enforces document ownership for writes while allowing public reads, a common pattern for marketplaces.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      allow update: if (isExistingOwner(resource.data.sellerMemberId) && request.resource.data.sellerMemberId == resource.data.sellerMemberId) || isAdmin();
      allow delete: if isExistingOwner(resource.data.sellerMemberId) || isAdmin();
    }

    /**
     * @description Controls access to fundraising causes.
     * @path /causes/{causeId}
     * @allow (read) - Authenticated users can read approved causes. Admins and creators can read any.
     * @allow (create) - Authenticated users can create a new cause for themselves.
     * @allow (update) - Admins can update. Users can contribute, updating amounts.
     */
    match /causes/{causeId} {
        allow get: if isSignedIn() && (resource.data.status == 'approved' || isOwner(resource.data.creatorMemberId) || isAdmin());
        allow list: if isSignedIn(); // Allow listing so client can filter by 'approved'
        allow create: if isOwner(request.resource.data.creatorMemberId);
        allow update: if isAdmin() || 
                        (isSignedIn() && 
                         request.resource.data.status == resource.data.status && // Prevent users from changing status
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentAmount', 'backersCount']));
        allow delete: if isAdmin();
    }

    /**
     * @description Controls access to ad campaigns.
     * @path /ads/{adId}
     * @allow (read) - Owner and admins can read.
     * @allow (create) - Owner can create.
     * @allow (update) - Owner can update (but not status), admin can update anything.
     * @allow (delete) - Owner and admin can delete.
     */
     match /ads/{adId} {
      allow read: if isOwner(resource.data.creatorMemberId) || isAdmin();
      allow create: if isOwner(request.resource.data.creatorMemberId);
      allow update: if isAdmin() || (isOwner(resource.data.creatorMemberId) && request.resource.data.status == resource.data.status);
      allow delete: if isOwner(resource.data.creatorMemberId) || isAdmin();
    }

    /**
     * @description Controls access to community posts.
     * @path /posts/{postId}
     * @allow (list, get) - Any authenticated user can read posts.
     * @allow (create) - A user can create their own post.
     * @allow (update) - A user can update their own post (e.g., edit content). For likes, a more granular rule or backend function is recommended.
     * @allow (delete) - A user can delete their own post, or an admin can.
     */
    match /posts/{postId} {
      allow list, get: if isSignedIn();
      allow create: if isOwner(request.resource.data.authorId);
      allow update: if isOwner(resource.data.authorId) || isAdmin(); // Simplified for now.
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
      
      /**
       * @description Controls access to comments on a post.
       * @path /posts/{postId}/comments/{commentId}
       * @allow (read) - Any authenticated user can read comments.
       * @allow (create) - A user can create their own comment.
       * @allow (update, delete) - The comment author or an admin can modify/delete.
       */
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isOwner(request.resource.data.authorId);
        allow update, delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }

    /**
     * @description Controls access to matchmaking recommendations stored at the top level.
     * @path /matchmaking_recommendations/{recommendationId}
     * @allow (read) - Admins can read all recommendations.
     * @allow (get) - A user can read a recommendation made for them.
     * @principle Enforces ownership via a denormalized field. Writes are disallowed as recommendations are system-generated.
     */
    match /matchmaking_recommendations/{recommendationId} {
      allow read: if isAdmin();
      allow get: if isOwner(resource.data.memberId);
      allow create: if false; // Recommendations are created by a backend service
      allow update: if false; // Recommendations are immutable
      allow delete: if false; // Recommendations are not deleted by users
    }
    
    // ------------------------------------------------------------------------
    // Chat Data
    // ------------------------------------------------------------------------

    match /chats/{chatId} {
      // A user can read or write to a chat if their UID is in the `members` array.
      // This rule supports both `get` and `list` queries. For `list`, the client
      // query MUST include `where('members', 'array-contains', request.auth.uid)`.
      allow read, write: if request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        // A user can read/write messages in a chat they are a member of.
        // This requires a `get` call to the parent chat document to check the `members` array.
        allow read, write: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }

    // ------------------------------------------------------------------------
    // Friend Requests
    // ------------------------------------------------------------------------
    match /friend_requests/{requestId} {
      // A user can create a request where they are the sender.
      allow create: if isOwner(request.resource.data.senderId);

      // The sender and recipient can read the request.
      allow read: if isOwner(resource.data.senderId) || isOwner(resource.data.recipientId);

      // The recipient can update the status to 'accepted' or 'declined'.
      // Sender and recipient cannot be changed.
      allow update: if isOwner(resource.data.recipientId)
                      && request.resource.data.senderId == resource.data.senderId
                      && request.resource.data.recipientId == resource.data.recipientId;

      // The sender can delete a pending request (cancel it).
      // The recipient can delete a request they have received.
      allow delete: if isOwner(resource.data.senderId) || isOwner(resource.data.recipientId);
    }
  }
}

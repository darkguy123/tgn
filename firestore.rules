rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================== */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'valentinoboss18@gmail.com' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'mentee')
            in ['admin', 'country-manager']
        )
      );
    }

    /* =========================
       USERS
    ========================== */
    match /users {
      allow list: if isSignedIn();
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();

      match /{sub=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    /* =========================
       POSTS & COMMENTS (HARDCODED READ)
    ========================== */
    match /posts {
      allow list: if true;
    }

    match /posts/{postId} {
      allow get: if true;

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid;

      // Allow social interactions (likes, saves) for everyone
      allow update: if isSignedIn();

      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.authorId == request.auth.uid);

      match /comments {
        allow list: if true;
      }

      match /comments/{commentId} {
        allow get: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin()
          || (isSignedIn() && resource.data.authorId == request.auth.uid);
      }
    }

    /* =========================
       PROGRAMS (HARDCODED READ)
    ========================== */
    match /programs {
      allow list: if true;
    }

    match /programs/{id} {
      allow get: if true;
      allow write: if isAdmin();
    }

    /* =========================
       PRODUCTS (HARDCODED READ)
    ========================== */
    match /products {
      allow list: if true;
    }

    match /products/{id} {
      allow get: if true;
      allow create: if isSignedIn()
        && request.resource.data.sellerMemberId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.sellerMemberId == request.auth.uid);
    }

    /* =========================
       FRIEND REQUESTS
    ========================== */
    match /friend_requests {
      allow list: if isSignedIn();
    }

    match /friend_requests/{id} {
      allow get, update, delete: if isSignedIn()
        && (
          resource.data.senderId == request.auth.uid ||
          resource.data.recipientId == request.auth.uid
        );

      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid;
    }

    /* =========================
       CHATS
    ========================== */
    match /chats {
      allow list: if isSignedIn();
    }

    match /chats/{chatId} {
      allow get, create, update: if isSignedIn()
        && (request.auth.uid in chatId.split('_') || request.auth.uid in resource.data.members);

      match /messages {
        allow list: if isSignedIn();
      }

      match /messages/{id} {
        allow read, create: if isSignedIn();
      }
    }

    /* =========================
       CONNECTIONS
    ========================== */
    match /connections {
      allow list: if isSignedIn();
    }

    match /connections/{id} {
      allow get, create, delete: if isSignedIn()
        && request.auth.uid in id.split('_');
    }

    /* =========================
       GLOBAL FALLBACK
    ========================== */
    match /{doc=**} {
      allow get, list: if isSignedIn();
      allow write: if false;
    }
  }
}
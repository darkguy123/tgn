rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------
    // Helper functions
    // ---------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resourceOwnerId) {
      return isSignedIn() && request.auth.uid == resourceOwnerId;
    }
    
    function isAdmin() {
      // Admin check: check for hardcoded master email OR check user profile role.
      return isSignedIn() && (
        (request.auth.token.email == 'valentinoboss18@gmail.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'mentee') in ['country-manager', 'admin'])
      );
    }

    // ---------------------------------------
    // Users collection
    // ---------------------------------------
    match /users/{userId} {
      
      // Allow authenticated users to view profiles and search the directory
      allow get, list: if isSignedIn();

      // User can create/update their own profile
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && (request.resource.data.get('role', 'mentee') == resource.data.get('role', 'mentee'))) || isAdmin();
      allow delete: if isAdmin();

      // Subcollections
      match /media/{mediaId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId) || isAdmin();
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isAdmin();
      }
      match /enrolled_programs/{programId} {
        allow read, create: if isOwner(userId) || isAdmin();
      }
    }

    // ---------------------------------------
    // Posts collection
    // ---------------------------------------
    match /posts/{postId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn(); // For likes/saves
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      }
    }

    // ---------------------------------------
    // Friend requests collection
    // ---------------------------------------
    match /friend_requests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      
      // Only sender or recipient can read/manage
      allow get: if isSignedIn() && 
                  (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      
      // Restricted listing: queries must filter by senderId or recipientId
      allow list: if isSignedIn() && (
                  request.query.limit <= 100 && (
                    request.query.where.senderId == request.auth.uid || 
                    request.query.where.recipientId == request.auth.uid
                  )
      );
      
      allow update, delete: if isSignedIn() && 
                  (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    // ---------------------------------------
    // Chats collection
    // ---------------------------------------
    match /chats/{chatId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid in resource.data.members || request.auth.uid in chatId.split('_'));
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        allow list, get: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }

    // ---------------------------------------
    // Global Access for other resources
    // ---------------------------------------
    match /programs/{programId} {
      allow list, get: if true;
      allow write: if isAdmin();
    }
    
    match /products/{productId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.sellerMemberId == request.auth.uid);
    }

    match /sectors/{sectorId} {
      allow list, get: if true;
      allow write: if isAdmin();
    }

    match /causes/{causeId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorMemberId == request.auth.uid;
      allow update: if isSignedIn();
    }

    match /ads/{adId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorMemberId == request.auth.uid;
      allow update: if isAdmin();
    }
    
    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /commissions/{id} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }
    
    match /affiliate_referrals/{id} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
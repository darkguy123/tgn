{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Represents a member of the Transcend Global Network Hub.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tgnMemberId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["mentee", "mentor-candidate", "associate-mentor", "collaborator", "sponsor", "country-manager", "volunteer", "media", "admin"] },
        "locationCountry": { "type": "string" },
        "sectorPreferences": { "type": "array", "items": { "type": "string" } },
        "avatarUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "isVerifiedMentor": { "type": "boolean" },
        "connections": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "tgnMemberId", "email", "role"]
    },
    "Chat": {
      "title": "Chat",
      "type": "object",
      "properties": {
        "members": { "type": "array", "items": { "type": "string" } },
        "lastMessage": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "senderId": { "type": "string" },
            "timestamp": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "recipientId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/Member" },
      "description": "User profiles and metadata."
    },
    "/friend_requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/FriendRequest" },
      "description": "Networking connection requests."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/backend/entities/Chat" },
      "description": "Private messaging sessions."
    }
  }
}
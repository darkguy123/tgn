
{
  "entities": {
    "Member": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Member",
      "type": "object",
      "description": "Represents a member of the Transcend Global Network Hub.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Member entity (matches Firebase Auth UID)." },
        "tgnMemberId": { "type": "string", "description": "Unique TGN Member ID assigned during onboarding." },
        "name": { "type": "string", "description": "The member's full name." },
        "signInType": { "type": "string", "description": "The authentication method used (e.g., 'password', 'google.com')." },
        "email": { "type": "string", "description": "The member's email address.", "format": "email" },
        "phone": { "type": "string", "description": "The member's phone number." },
        "locationContinent": { "type": "string" },
        "locationCountry": { "type": "string" },
        "locationRegion": { "type": "string" },
        "timezone": { "type": "string" },
        "sectorPreferences": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["mentee", "mentor-candidate", "associate-mentor", "collaborator", "sponsor", "country-manager", "volunteer", "media", "admin"] },
        "purpose": { "type": "string", "description": "The member's bio or statement of purpose." },
        "identityProfile": { "type": "string", "description": "A JSON string containing member's goals and interests." },
        "avatarUrl": { "type": "string", "description": "URL to the member's profile image." },
        "bannerUrl": { "type": "string", "description": "URL for the user's profile banner image." },
        "isVerifiedMentor": { "type": "boolean", "default": false },
        "hasTransactionPin": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "connections": { "type": "array", "items": { "type": "string" } },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "emailUpdates": { "type": "boolean" },
            "sessionReminders": { "type": "boolean" },
            "communityActivity": { "type": "boolean" },
            "marketingEmails": { "type": "boolean" },
            "pushNotifications": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "tgnMemberId", "email", "role"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "sellerMemberId": { "type": "string" },
        "approvalStatus": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/Member" },
      "description": "User profiles and metadata. Readable by all signed-in users, writable by owner."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/backend/entities/Post" },
      "description": "Global community posts. Publicly readable, writable by author."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Marketplace products. Publicly readable, writable by seller."
    },
    "/{document=**}": {
      "description": "Global fallback for reading data, enforcing ownership for writes to prevent crashes."
    }
  }
}

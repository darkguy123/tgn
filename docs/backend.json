{
  "entities": {
    "TGNMember": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TGNMember",
      "type": "object",
      "description": "Represents a member of the Transcend Global Network.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the TGN Member.",
          "format": "uuid"
        },
        "tgnMemberId": {
          "type": "string",
          "description": "Unique TGN Member ID assigned during onboarding."
        },
        "location": {
          "type": "string",
          "description": "Member's location (e.g., city, country)."
        },
        "sectorPreferences": {
          "type": "array",
          "description": "List of sector preferences for the member.",
          "items": {
            "type": "string"
          }
        },
        "role": {
          "type": "string",
          "description": "Member's role (e.g., mentee, mentor, associate)."
        },
        "learningHistoryIds": {
          "type": "array",
          "description": "References to LearningHistory. (Relationship: TGNMember 1:N LearningHistory)",
          "items": {
            "type": "string"
          }
        },
        "engagementScore": {
          "type": "number",
          "description": "Member's engagement score."
        },
        "programIds": {
          "type": "array",
          "description": "References to Programs. (Relationship: TGNMember N:N Program)",
          "items": {
            "type": "string"
          }
        },
        "communityIds": {
          "type": "array",
          "description": "References to Communities. (Relationship: TGNMember N:N Community)",
          "items": {
            "type": "string"
          }
        },
        "eventIds": {
          "type": "array",
          "description": "References to Events. (Relationship: TGNMember N:N Event)",
          "items": {
            "type": "string"
          }
        },
        "isMenteeVerified": {
          "type": "boolean",
          "description": "Indicates if the mentee is verified."
        },
        "mentorCertificationId": {
          "type": "string",
          "description": "Reference to MentorCertification. (Relationship: TGNMember 1:1 MentorCertification)"
        }
      },
      "required": [
        "id",
        "tgnMemberId",
        "location",
        "sectorPreferences",
        "role"
      ]
    },
    "AdCampaign": {
      "title": "AdCampaign",
      "description": "Represents an advertisement campaign created by a member.",
      "type": "object",
      "properties": {
        "creatorMemberId": {
          "type": "string",
          "description": "The UID of the member who created the ad."
        },
        "creatorName": {
          "type": "string"
        },
        "creatorAvatarUrl": {
          "type": "string",
          "format": "uri"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_review",
            "active",
            "paused",
            "rejected"
          ]
        },
        "budget": {
          "type": "number"
        },
        "amountSpent": {
          "type": "number"
        },
        "headline": {
          "type": "string"
        },
        "bodyText": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string",
          "format": "uri"
        },
        "callToActionText": {
          "type": "string"
        },
        "callToActionUrl": {
          "type": "string",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "rejectionReason": {
          "type": "string"
        },
        "adSize": {
          "type": "string",
          "enum": [
            "350x350",
            "128x90",
            "skyscraper"
          ]
        },
        "promotedProductId": {
          "type": "string"
        },
        "promotedProgramId": {
          "type": "string"
        }
      },
      "required": [
        "creatorMemberId",
        "creatorName",
        "name",
        "status",
        "budget",
        "headline",
        "bodyText",
        "imageUrl",
        "callToActionText",
        "callToActionUrl",
        "createdAt",
        "adSize"
      ]
    },
    "Cause": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Cause",
      "type": "object",
      "description": "Represents a fundraising cause created by a member.",
      "properties": {
        "creatorMemberId": {
          "type": "string",
          "description": "The UID of the member who created the cause."
        },
        "creatorName": {
          "type": "string"
        },
        "creatorAvatarUrl": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "goalAmount": {
          "type": "number"
        },
        "currentAmount": {
          "type": "number"
        },
        "backersCount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "creatorMemberId",
        "creatorName",
        "title",
        "description",
        "goalAmount",
        "currentAmount",
        "status",
        "createdAt"
      ]
    },
    "MentorCertification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MentorCertification",
      "type": "object",
      "description": "Represents the certification status of a mentor.",
      "properties": {
        "memberId": {
          "type": "string",
          "description": "The UID of the member this certification belongs to. This should match the document ID."
        },
        "paidProgramsCompleted": {
          "type": "number",
          "description": "Number of paid programs completed by the member."
        },
        "accountAgeInMonths": {
          "type": "number",
          "description": "Number of months the member has been active."
        },
        "menteeBadgeLevel": {
          "type": "number",
          "description": "The member's badge level as a mentee."
        },
        "curriculumCompleted": {
          "type": "boolean",
          "description": "Indicates if the member has completed the certification curriculum."
        },
        "evaluationPassed": {
          "type": "boolean",
          "description": "Indicates if the member has passed the TGN evaluation."
        },
        "isCertified": {
          "type": "boolean",
          "description": "Indicates if the member is a certified mentor."
        },
        "certificationDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date the certification was awarded."
        }
      },
      "required": [
        "memberId",
        "paidProgramsCompleted",
        "accountAgeInMonths",
        "menteeBadgeLevel",
        "curriculumCompleted",
        "evaluationPassed",
        "isCertified"
      ]
    },
    "LearningHistory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LearningHistory",
      "type": "object",
      "description": "Represents the learning history of a member.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Learning History entry.",
          "format": "uuid"
        },
        "courseId": {
          "type": "string",
          "description": "Reference to Course. (Relationship: LearningHistory 1:1 Course)"
        },
        "completionDate": {
          "type": "string",
          "description": "Date of course completion.",
          "format": "date-time"
        },
        "score": {
          "type": "number",
          "description": "Score obtained in the course."
        }
      },
      "required": [
        "id",
        "courseId",
        "completionDate",
        "score"
      ]
    },
    "Program": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Program",
      "type": "object",
      "description": "Represents a program offered by the network.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Program.",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "description": "Name of the program."
        },
        "description": {
          "type": "string",
          "description": "Description of the program."
        },
        "sectorId": {
          "type": "string",
          "description": "Reference to Sector. (Relationship: Program 1:N Sector)"
        },
        "memberIds": {
          "type": "array",
          "description": "References to TGNMembers. (Relationship: Program N:N TGNMember)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "sectorId"
      ]
    },
    "Community": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Community",
      "type": "object",
      "description": "Represents a community within the network.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Community.",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "description": "Name of the community."
        },
        "description": {
          "type": "string",
          "description": "Description of the community."
        },
        "memberIds": {
          "type": "array",
          "description": "References to TGNMembers. (Relationship: Community N:N TGNMember)",
          "items": {
            "type": "string"
          }
        },
        "sectorId": {
          "type": "string",
          "description": "Reference to Sector. (Relationship: Community 1:N Sector)"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "sectorId"
      ]
    },
    "Event": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Event",
      "type": "object",
      "description": "Represents an event organized by the network.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Event.",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "description": "Name of the event."
        },
        "description": {
          "type": "string",
          "description": "Description of the event."
        },
        "dateTime": {
          "type": "string",
          "description": "Date and time of the event.",
          "format": "date-time"
        },
        "location": {
          "type": "string",
          "description": "Location of the event."
        },
        "memberIds": {
          "type": "array",
          "description": "References to TGNMembers. (Relationship: Event N:N TGNMember)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "dateTime",
        "location"
      ]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "description": "Represents a course offered on the platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Course.",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "description": "Name of the course."
        },
        "description": {
          "type": "string",
          "description": "Description of the course."
        },
        "price": {
          "type": "number",
          "description": "Price of the course."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "price"
      ]
    },
    "AffiliateReferral": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AffiliateReferral",
      "type": "object",
      "description": "Represents a referral in the affiliate income system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Referral.",
          "format": "uuid"
        },
        "referrerMemberId": {
          "type": "string",
          "description": "Reference to the TGNMember who made the referral. (Relationship: AffiliateReferral 1:N TGNMember)"
        },
        "referredMemberId": {
          "type": "string",
          "description": "Reference to the TGNMember who was referred. (Relationship: AffiliateReferral 1:N TGNMember)"
        },
        "referralDate": {
          "type": "string",
          "description": "Date of the referral.",
          "format": "date-time"
        },
        "level": {
          "type": "number",
          "description": "Referral level (1-7)."
        },
        "earnings": {
          "type": "number",
          "description": "Earnings from the referral."
        }
      },
      "required": [
        "id",
        "referrerMemberId",
        "referredMemberId",
        "referralDate",
        "level",
        "earnings"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a listing in the e-commerce marketplace.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product.",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "description": "Name of the product."
        },
        "description": {
          "type": "string",
          "description": "Description of the product."
        },
        "price": {
          "type": "number",
          "description": "Price of the product."
        },
        "type": {
          "type": "string",
          "enum": [
            "Book",
            "Course",
            "Tool",
            "Digital Asset"
          ],
          "description": "The category of the product."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the product image."
        },
        "sellerMemberId": {
          "type": "string",
          "description": "Reference to the TGNMember selling the item."
        },
        "sellerName": {
          "type": "string",
          "description": "Denormalized name of the seller for display."
        },
        "sellerAvatarUrl": {
          "type": "string",
          "format": "uri",
          "description": "Denormalized avatar URL of the seller."
        },
        "approvalStatus": {
          "type": "string",
          "description": "Approval status of the product (e.g., pending, approved, rejected).",
          "enum": [
            "pending",
            "in_review",
            "approved",
            "rejected"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the product was created."
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "price",
        "type",
        "imageUrl",
        "sellerMemberId",
        "sellerName",
        "approvalStatus",
        "createdAt"
      ]
    },
    "PackageBenefits": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PackageBenefits",
      "type": "object",
      "description": "Represents package benefits for marketplace listings.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Package Benefit.",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "description": "Name of the package benefit."
        },
        "description": {
          "type": "string",
          "description": "Description of the package benefit."
        }
      },
      "required": [
        "id",
        "name",
        "description"
      ]
    },
    "Sector": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Sector",
      "type": "object",
      "description": "Represents different business sectors.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Sector.",
          "format": "uuid"
        },
        "name": {
          "type": "string",
          "description": "Name of the sector."
        },
        "description": {
          "type": "string",
          "description": "Description of the sector."
        }
      },
      "required": [
        "id",
        "name",
        "description"
      ]
    },
    "FriendRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FriendRequest",
      "type": "object",
      "description": "Represents a connection request between two members.",
      "properties": {
        "senderId": {
          "type": "string",
          "description": "The UID of the member sending the request."
        },
        "recipientId": {
          "type": "string",
          "description": "The UID of the member receiving the request."
        },
        "status": {
          "type": "string",
          "description": "The current status of the request.",
          "enum": [
            "pending",
            "accepted",
            "declined"
          ]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the request was created.",
          "format": "date-time"
        }
      },
      "required": [
        "senderId",
        "recipientId",
        "status",
        "createdAt"
      ]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a post in the community feed.",
      "properties": {
        "authorId": {
          "type": "string",
          "description": "The UID of the member who created the post."
        },
        "authorTgnMemberId": {
          "type": "string"
        },
        "authorName": {
          "type": "string"
        },
        "authorAvatarUrl": {
          "type": "string"
        },
        "authorRole": {
          "type": "string"
        },
        "content": {
          "type": "string",
          "description": "The text content of the post."
        },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        },
        "likes": {
          "type": "number"
        },
        "commentsCount": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the post was created.",
          "format": "date-time"
        }
      },
      "required": [
        "authorId",
        "authorName",
        "content",
        "createdAt"
      ]
    },
    "Comment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "authorId": {
          "type": "string"
        },
        "authorName": {
          "type": "string"
        },
        "authorAvatarUrl": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "authorId",
        "authorName",
        "content",
        "createdAt"
      ]
    },
    "MediaFile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MediaFile",
      "type": "object",
      "description": "Represents a user-uploaded file.",
      "properties": {
        "ownerId": {
          "type": "string"
        },
        "fileName": {
          "type": "string"
        },
        "fileType": {
          "type": "string"
        },
        "fileSize": {
          "type": "number"
        },
        "storagePath": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "ownerId",
        "fileName",
        "fileType",
        "fileSize",
        "storagePath",
        "url",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "TGNMember",
          "schema": {
            "$ref": "#/backend/entities/TGNMember"
          },
          "description": "Stores TGNMember data, using the user's ID as the document ID for easy access control.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user, corresponding to their Firebase Auth UID."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/learningHistories/{learningHistoryId}",
        "definition": {
          "entityName": "LearningHistory",
          "schema": {
            "$ref": "#/backend/entities/LearningHistory"
          },
          "description": "Stores the learning history of a member, nested under the user's document. This enables easy management and querying of learning data per user.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            },
            {
              "name": "learningHistoryId",
              "description": "The unique identifier of the learning history entry."
            }
          ]
        }
      },
      {
        "path": "/mentor_certifications/{userId}",
        "definition": {
          "entityName": "MentorCertification",
          "schema": {
            "$ref": "#/backend/entities/MentorCertification"
          },
          "description": "Stores mentor certification progress. The document ID is the user's UID.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user this certification belongs to."
            }
          ]
        }
      },
      {
        "path": "/programs/{programId}",
        "definition": {
          "entityName": "Program",
          "schema": {
            "$ref": "#/backend/entities/Program"
          },
          "description": "Stores program information.  No specific authorization context denormalized here; access is likely managed via membership in the TGNMember document.",
          "params": [
            {
              "name": "programId",
              "description": "The unique identifier of the program."
            }
          ]
        }
      },
      {
        "path": "/communities/{communityId}",
        "definition": {
          "entityName": "Community",
          "schema": {
            "$ref": "#/backend/entities/Community"
          },
          "description": "Stores community information. No specific authorization context denormalized here; access is likely managed via membership in the TGNMember document.",
          "params": [
            {
              "name": "communityId",
              "description": "The unique identifier of the community."
            }
          ]
        }
      },
      {
        "path": "/events/{eventId}",
        "definition": {
          "entityName": "Event",
          "schema": {
            "$ref": "#/backend/entities/Event"
          },
          "description": "Stores event information. No specific authorization context denormalized here; access is likely managed via membership in the TGNMember document.",
          "params": [
            {
              "name": "eventId",
              "description": "The unique identifier of the event."
            }
          ]
        }
      },
      {
        "path": "/courses/{courseId}",
        "definition": {
          "entityName": "Course",
          "schema": {
            "$ref": "#/backend/entities/Course"
          },
          "description": "Stores course information. No specific authorization context denormalized here; access is likely managed via membership in the TGNMember document.",
          "params": [
            {
              "name": "courseId",
              "description": "The unique identifier of the course."
            }
          ]
        }
      },
      {
        "path": "/affiliateReferrals/{affiliateReferralId}",
        "definition": {
          "entityName": "AffiliateReferral",
          "schema": {
            "$ref": "#/backend/entities/AffiliateReferral"
          },
          "description": "Stores affiliate referral data.  No direct user ownership; access control would likely depend on admin roles or other factors outside user control.",
          "params": [
            {
              "name": "affiliateReferralId",
              "description": "The unique identifier of the affiliate referral."
            }
          ]
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Stores product listings. The `sellerMemberId` field is used for authorization to control access based on ownership.",
          "params": [
            {
              "name": "productId",
              "description": "The unique identifier of the product."
            }
          ]
        }
      },
      {

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // PUBLIC UPLOADS (profile pics, post media, etc.)
    // Anyone can read these files.
    // Only the authenticated owner can create, update, or delete.
    match /uploads/public/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // PRIVATE UPLOADS (KYC documents, etc.)
    // Only the authenticated owner can read or write these files.
    match /uploads/private/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Fallback rule to deny all other routes
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

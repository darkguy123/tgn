rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // This rule allows any authenticated user to write to a folder matching their UID.
    // It also allows public read access, which is necessary for profile pictures, etc.
    match /uploads/public/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }

    // This rule allows ONLY the authenticated user to read or write to their own private folder.
    // This is for sensitive documents like KYC uploads.
    match /uploads/private/{userId}/{allPaths=**} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Publicly readable files
    match /uploads/public/{userId}/{fileName} {
      allow read: if true;

      // For new uploads, check the metadata being sent.
      allow create: if isOwner(request.resource.metadata.ownerId);

      // For updates, only the owner can update.
      allow update: if isOwner(resource.metadata.ownerId);
      
      // For deletes, check the metadata on the existing file.
      allow delete: if isOwner(resource.metadata.ownerId);
    }

    // Files only accessible by their owner
    match /uploads/private/{userId}/{fileName} {
      allow read: if isOwner(resource.metadata.ownerId);
      allow create: if isOwner(request.resource.metadata.ownerId);
      allow update: if isOwner(resource.metadata.ownerId);
      allow delete: if isOwner(resource.metadata.ownerId);
    }
  }
}

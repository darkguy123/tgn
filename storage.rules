rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Public Area ---
    match /uploads/public/{allPaths=**} {
      // Anyone can read public files.
      allow read: if true;

      // Users can write (create, update) if their UID matches the ownerId in the file metadata.
      allow create, update: if request.auth.uid == request.resource.metadata.ownerId;
      
      // Users can delete files if their UID matches the ownerId in the existing file's metadata.
      allow delete: if request.auth.uid == resource.metadata.ownerId;
    }

    // --- Private Area ---
    match /uploads/private/{allPaths=**} {
       // Users can read their own private files. `resource` refers to the existing file.
       allow read: if request.auth.uid == resource.metadata.ownerId;

       // Users can write (create, update, delete) to their own private files.
       allow create, update: if request.auth.uid == request.resource.metadata.ownerId;
       allow delete: if request.auth.uid == resource.metadata.ownerId;
    }
  }
}

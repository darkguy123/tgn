rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Allow public read on all files in the uploads folder
    match /uploads/{allPaths=**} {
      allow read;
    }

    // Allow users to write only to their own user-specific folder within uploads.
    match /uploads/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

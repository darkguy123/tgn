rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to everyone for public images.
    // Allow write access only to authenticated users to upload their own files.
    // A more secure ruleset would restrict writes to specific paths based on UID.
    match /{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
  }
}

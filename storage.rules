rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public user content (avatars, product images)
    match /uploads/public/{userId}/{allPaths=**} {
      allow read; // Anyone can read public content
      allow write: if request.auth != null && request.auth.uid == userId; // Only owner can write
    }

    // Private user content (KYC documents)
    match /uploads/private/{userId}/{allPaths=**} {
      // Only owner and super admin can read/write private content
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'valentinoboss18@gmail.com');
    }
  }
}

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Public Area ---
    match /uploads/public/{userId}/{fileName} {
      // Anyone can read public files.
      allow read: if true;

      // Users can write (create) if their UID matches the userId in the path.
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Users can delete files if their UID matches the userId in the path.
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Disallow updates to prevent overwriting.
      allow update: if false;
    }

    // --- Private Area ---
    match /uploads/private/{userId}/{fileName} {
       // Users can read their own private files.
       allow read: if request.auth != null && request.auth.uid == userId;

       // Users can write (create, update, delete) to their own private files.
       allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

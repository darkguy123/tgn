rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Admin check: check for hardcoded master email OR check user profile role.
      return isSignedIn() && (
        (request.auth.token.email == 'valentinoboss18@gmail.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'mentee') in ['country-manager', 'admin'])
      );
    }

    // --- COLLECTION-LEVEL LIST RULES (TOP LEVEL - FIXES "method: list" errors) ---
    match /users { allow list: if isSignedIn(); }
    match /posts { allow list: if isSignedIn(); }
    match /programs { allow list: if isSignedIn(); }
    match /products { allow list: if isSignedIn(); }
    match /friend_requests { allow list: if isSignedIn(); }
    match /ads { allow list: if isSignedIn(); }
    match /causes { allow list: if isSignedIn(); }
    match /commissions { allow list: if isSignedIn(); }
    match /affiliate_referrals { allow list: if isSignedIn(); }
    match /chats { allow list: if isSignedIn(); }
    match /sectors { allow list: if true; }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && (request.resource.data.get('role', 'mentee') == resource.data.get('role', 'mentee'))) || isAdmin();

      match /media/{mediaId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId) || isAdmin();
        allow update: if false;
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /transactions/{transactionId} {
        allow create: if isOwner(userId);
        allow read: if isOwner(userId) || isAdmin();
        allow update: if isAdmin(); 
        allow delete: if false;
      }
      match /enrolled_programs/{programId} {
          allow read, create: if isOwner(userId) || isAdmin();
          allow update, delete: if isAdmin();
      }
    }
    
    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- POSTS ---
    match /posts/{postId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn(); // For likes/saves
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      }
    }

    // --- CHAT & MESSAGES ---
    match /chats/{chatId} {
      allow get: if isSignedIn() && (request.auth.uid in resource.data.members || request.auth.uid in chatId.split('_'));
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages { allow list: if isSignedIn(); }
      match /messages/{messageId} {
        allow get: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // --- FRIEND REQUESTS ---
    match /friend_requests/{requestId} {
      // Logic: User must be sender or recipient to see details
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    // --- GLOBAL FALLBACK PATTERN ---
    match /{document=**} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (
        isAdmin() ||
        (request.resource.data.get('userId', '') == request.auth.uid) ||
        (request.resource.data.get('authorId', '') == request.auth.uid) ||
        (request.resource.data.get('sellerMemberId', '') == request.auth.uid) ||
        (request.resource.data.get('creatorMemberId', '') == request.auth.uid) ||
        (request.resource.data.get('memberId', '') == request.auth.uid)
      );
    }
  }
}
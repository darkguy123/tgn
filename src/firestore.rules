rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return (request.auth.token.email == 'valentinoboss18@gmail.com') || 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'country-manager');
    }

    // --- USER DATA ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      // Prevent users from changing their own role, but allow admin
      allow update: if (isOwner(userId) && !(request.resource.data.role != resource.data.role)) || isAdmin();

      match /media/{mediaId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId);
      }
      match /transactions/{transactionId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false;
      }
      match /enrolled_programs/{programId} {
          allow read, create: if isOwner(userId);
          allow update, delete: if false;
      }
    }
    
    // --- WALLETS ---
    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- PUBLIC/GLOBAL DATA ---
    match /programs/{programId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /sectors/{sectorId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- CHAT & CONNECTIONS ---
    match /chats/{chatId} {
      allow get: if isSignedIn() && chatId.split('_').includes(request.auth.uid);
      allow list: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        function isChatMember() {
          return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        }
        allow read: if isChatMember();
        allow create: if isChatMember() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    match /friend_requests/{friendRequestId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }
    
    // --- COMMUNITY & USER-GENERATED CONTENT ---
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn(); // For likes
      allow delete: if isOwner(resource.data.authorId) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if (isSignedIn() && resource.data.sellerMemberId == request.auth.uid) || isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /causes/{causeId} {
      allow read: if true;
      allow create: if isSignedIn();
      // Any signed in user can update (to back a cause), creator or admin can also edit.
      allow update: if isSignedIn();
    }
    
    // --- ADMIN & VERIFICATION ---
    match /mentor_certifications/{memberId} {
      allow read: if isOwner(memberId) || isAdmin();
      allow write: if isAdmin();
    }
    match /mentor_kyc/{memberId} {
      allow read: if isOwner(memberId) || isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin(); // User can update, admin can update status
    }
    
    // --- AFFILIATE SYSTEM ---
    match /commissions/{commissionId} {
      allow read: if isSignedIn() && resource.data.referrerId == request.auth.uid;
      allow create: if isSignedIn(); // Created during a transaction by another user
      allow update, delete: if false;
    }
    
    match /affiliate_referrals/{referralId} {
      allow read: if isSignedIn() && (resource.data.referrerMemberId == request.auth.uid || resource.data.referredMemberId == request.auth.uid);
      allow create: if isSignedIn(); // Created during onboarding by new user
      allow update, delete: if false;
    }
  }
}

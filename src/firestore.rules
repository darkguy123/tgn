
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Safely check for admin privileges.
      // 1. Check hardcoded super-admin email
      // 2. Check user document role if it exists
      return isSignedIn() && (
        (request.auth.token.email == 'valentinoboss18@gmail.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['country-manager', 'admin'])
      );
    }

    // --- COLLECTION GROUP RULES ---
    match /{path=**}/transactions/{transactionId} {
      // Allow admin to list and get any transaction for review/approval
      allow read: if isAdmin();
    }

    // --- USER-OWNED DATA ---
    match /users/{userId} {
      allow read: if true; // Publicly readable profiles
      allow create: if isOwner(userId); // User can create their own document
      // User can update their own doc, but cannot change their role. Admin can do anything.
      allow update: if (isOwner(userId) && !(request.resource.data.role != resource.data.role)) || isAdmin();

      // Subcollections
      match /media/{mediaId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
        allow update: if false; // Disallow updates to media docs
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId);
      }
      match /transactions/{transactionId} {
        allow create: if isOwner(userId);
        allow read: if isOwner(userId) || isAdmin(); // Let admin read single doc too
        // Admin can update status (e.g., from pending to completed/failed)
        allow update: if isAdmin(); 
        allow delete: if false;
      }
      match /enrolled_programs/{programId} {
          allow read, create: if isOwner(userId);
          allow update, delete: if false;
      }
    }
    
    // Wallets are keyed by user ID
    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- GLOBAL/PUBLIC DATA ---
    match /programs/{programId} {
      allow read: if isSignedIn(); // Any signed-in user can read programs
      allow write: if isAdmin(); // Only admins can create/update programs
    }
    match /sectors/{sectorId} {
      allow read: if true; // Publicly readable reference data
      allow write: if isAdmin();
    }
    match /events/{eventId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // --- COMMUNITY & USER-GENERATED CONTENT ---
    match /posts/{postId} {
      // Explicitly allow list and get for signed-in users
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      // Allow any signed-in user to update (for liking/saving).
      allow update: if isSignedIn();
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if false; // Comments are immutable
      }
    }
    
    match /products/{productId} {
      allow read: if true; // Publicly readable marketplace
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      // Only the seller or an admin can update/delete
      allow update, delete: if (isSignedIn() && resource.data.sellerMemberId == request.auth.uid) || isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn(); // Any signed-in user can create an ad
      allow update: if isAdmin(); // Only admins can approve/reject/pause ads
    }

    match /causes/{causeId} {
      allow read: if true; // Publicly readable fundraisers
      allow create: if isSignedIn(); // Any signed-in user can create a cause
      // Any signed-in user can update (to contribute/back a cause).
      allow update: if isSignedIn();
    }
    
    // --- CHAT & CONNECTIONS ---
    match /chats/{chatId} {
      // A user can read a chat document if their UID is in the chatId.
      allow get: if isSignedIn() && request.auth.uid in chatId.split('_');
      allow list: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in chatId.split('_');
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid && request.auth.uid in chatId.split('_');
        allow update, delete: if false;
      }
    }
    
    match /friend_requests/{friendRequestId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid; // Recipient can accept/decline
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    match /connections/{connectionId} {
      // A connection document ID is usually "uid1_uid2"
      allow read: if isSignedIn() && request.auth.uid in connectionId.split('_');
      allow delete: if isSignedIn() && request.auth.uid in connectionId.split('_');
      allow create: if isSignedIn() && request.auth.uid in connectionId.split('_');
    }
    
    // --- ADMIN & VERIFICATION ---
    match /mentor_certifications/{memberId} {
      allow read: if isOwner(memberId) || isAdmin();
      allow write: if isAdmin();
    }

    match /mentor_kyc/{memberId} {
      allow read: if isOwner(memberId) || isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin();
    }
    
    // --- AFFILIATE SYSTEM ---
    match /commissions/{commissionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn(); 
      allow update, delete: if false;
    }
    
    match /affiliate_referrals/{referralId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.referrerMemberId == request.auth.uid || resource.data.referredMemberId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}


rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Safely check for admin privileges.
      // 1. Check hardcoded super-admin email
      // 2. Check user document role if it exists
      return isSignedIn() && (
        (request.auth.token.email == 'valentinoboss18@gmail.com') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['country-manager', 'admin'])
      );
    }

    // --- COLLECTION GROUP RULES ---
    match /{path=**}/transactions/{transactionId} {
      // Allow admin to list and get any transaction for review/approval
      allow read: if isAdmin();
    }

    // --- USERS ---
    // 🔑 COLLECTION-LEVEL RULE
    match /users {
      allow list: if isSignedIn();
    }
    
    match /users/{userId} {
      // 👀 Individual document get
      allow get: if isSignedIn();
      
      // ✍️ User can create their own doc. Admin can too.
      allow create: if isOwner(userId) || isAdmin();
      
      // ✏️ User can update their own doc (but not their role). Admin can do anything.
      allow update: if (isOwner(userId) && (request.resource.data.role == resource.data.role)) || isAdmin();

      // Subcollections
      match /media/{mediaId} {
        allow read: if true;
        allow create, delete: if isOwner(userId) || isAdmin();
        allow update: if false;
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /transactions/{transactionId} {
        allow create: if isOwner(userId);
        allow read: if isOwner(userId) || isAdmin();
        allow update: if isAdmin(); 
        allow delete: if false;
      }
      match /enrolled_programs/{programId} {
          allow read, create: if isOwner(userId) || isAdmin();
          allow update, delete: if isAdmin();
      }
      match /menteeVerifications/{verificationId} {
          allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Wallets are private to the owner and admin
    match /wallets/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- POSTS (Social Media Style) ---
    // 🔑 COLLECTION-LEVEL RULE (THIS FIXES THE ERROR)
    match /posts {
      allow list: if isSignedIn();
    }

    match /posts/{postId} {
      // 👀 Document-level get
      allow get: if isSignedIn();

      // ✍️ Create post (author must be the creator)
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;

      // ✏️ Update: Allow any signed-in user to update (for liking/saving posts)
      allow update: if isSignedIn();
      
      // 🗑️ Delete only by owner or admin
      allow delete: if (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      }
    }

    // --- MARKETPLACE & CONTENT ---
    match /products {
      allow list: if true;
    }
    match /products/{productId} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid;
      allow update, delete: if (isSignedIn() && request.resource.data.sellerMemberId == request.auth.uid) || isAdmin();
    }

    match /programs {
      allow list: if isSignedIn();
    }
    match /programs/{programId} {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }

    match /events {
      allow list: if true;
    }
    match /events/{eventId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /sectors {
      allow list: if true;
    }
    match /sectors/{sectorId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    // --- ADS & CAUSES ---
    match /ads {
      allow list: if true;
    }
    match /ads/{adId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /causes {
      allow list: if true;
    }
    match /causes/{causeId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); 
    }
    
    // --- CHAT & CONNECTIONS ---
    match /chats {
      allow list: if isSignedIn();
    }
    match /chats/{chatId} {
      allow get: if isSignedIn() && (request.auth.uid in chatId.split('_') || request.auth.uid in resource.data.members);
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in chatId.split('_');
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    
    match /friend_requests {
      allow list: if isSignedIn();
    }
    match /friend_requests/{friendRequestId} {
      allow get: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid || resource.data.senderId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    match /connections {
      allow list: if isSignedIn();
    }
    match /connections/{connectionId} {
      allow get: if isSignedIn();
      allow create, delete: if isSignedIn() && request.auth.uid in connectionId.split('_');
    }
    
    // --- ADMIN & VERIFICATION ---
    match /mentor_certifications {
      allow list: if isAdmin();
    }
    match /mentor_certifications/{memberId} {
      allow get: if isOwner(memberId) || isAdmin();
      allow write: if isAdmin();
    }

    match /mentor_kyc {
      allow list: if isAdmin();
    }
    match /mentor_kyc/{memberId} {
      allow get: if isOwner(memberId) || isAdmin();
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId) || isAdmin();
    }
    
    // --- AFFILIATE SYSTEM ---
    match /commissions {
      allow list: if isSignedIn();
    }
    match /commissions/{commissionId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.referrerId == request.auth.uid);
      allow create: if isSignedIn(); 
      allow update, delete: if false;
    }
    
    match /affiliate_referrals {
      allow list: if isSignedIn();
    }
    match /affiliate_referrals/{referralId} {
      allow get: if isAdmin() || (isSignedIn() && (resource.data.referrerMemberId == request.auth.uid || resource.data.referredMemberId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
